                       libraryPath="c:\mes apps\onnxruntime\onnxruntime-win-x64-1.16.3\lib"
                       externalLibraries="onnxruntime.lib;shlwapi.lib;version.lib;runtimeobject.lib" preprocessorDefinitions="JUCE_USE_WIN_WEBVIEW2=1"/>
        <CONFIGURATION isDebug="0" name="Release" targetName="NADA BOSS Vocal Suite" headerPath="c:\mes apps\onnxruntime\onnxruntime-win-x64-1.16.3\include;../../Source/dsp;../../Source/gui;../../Source/ai;../../JuceLibraryCode"
                       libraryPath="c:\mes apps\onnxruntime\onnxruntime-win-x64-1.16.3\lib"
                       externalLibraries="onnxruntime.lib;shlwapi.lib;version.lib;runtimeobject.lib" preprocessorDefinitions="JUCE_USE_WIN_WEBVIEW2=1"/>
      </CONFIGURATIONS>
      <MODULEPATHS>
