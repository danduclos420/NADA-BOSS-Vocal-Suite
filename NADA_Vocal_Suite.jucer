<?xml version="1.0" encoding="UTF-8"?>

<JUCERPROJECT id="NADA01" name="NADA BOSS Vocal Suite" projectType="audioplug"
              useAppConfig="1" addUsingNamespaceToJuceHeader="0" displaySplashScreen="1"
              jucerFormatVersion="1" companyName="Antigravity AI" pluginFormats="buildVST3"
              pluginCharacteristicsValue="pluginIsSynth,pluginWantsMidiIn">
  <MAINGROUP id="mainGroup" name="NADA BOSS Vocal Suite">
    <GROUP id="{SOURCE}" name="Source">
      <GROUP id="dsp" name="dsp">
        <FILE id="PluginProcessorH" name="PluginProcessor.h" compile="0" resource="0"
