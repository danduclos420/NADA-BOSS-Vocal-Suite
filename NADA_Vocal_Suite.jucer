        <FILE id="PluginProcessorCPP" name="PluginProcessor.cpp" compile="1"
              resource="0" file="Source/dsp/PluginProcessor.cpp"/>
        <FILE id="NADAPitchShifterH" name="NADAPitchShifter.h" compile="0"
              resource="0" file="Source/dsp/NADAPitchShifter.h"/>
      </GROUP>
      <GROUP id="gui" name="gui">
        <FILE id="PluginEditorH" name="PluginEditor.h" compile="0" resource="0"
              file="Source/gui/PluginEditor.h"/>
        <FILE id="PluginEditorCPP" name="PluginEditor.cpp" compile="1" resource="0"
              file="Source/gui/PluginEditor.cpp"/>
      </GROUP>
      <GROUP id="ai" name="ai">
        <FILE id="ONNXModelManagerH" name="ONNXModelManager.h" compile="0"
              resource="0" file="Source/ai/ONNXModelManager.h"/>
      </GROUP>
    </GROUP>
  </MAINGROUP>
  <EXPORTFORMATS>
    <VS2022 targetFolder="Builds/VisualStudio2022" headerPath="../../Source/dsp;../../Source/gui;../../Source/ai"
